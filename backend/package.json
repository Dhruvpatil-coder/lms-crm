{
  "name": "unnatva-backend",
  "version": "2.0.0",
  "description": "Unnatva Backend - Lead & Placement Management",
  "main": "src/index.js",
  "scripts": {
    "start":     "node src/index.js",
    "dev":       "nodemon src/index.js",
    "db:push":   "npx prisma db push",
    "db:seed":   "node src/seed.js",
    "db:reset":  "npx prisma db push --force-reset && node src/seed.js",
    "db:studio": "npx prisma studio",
    "setup":     "npm install && npx prisma generate && npx prisma db push && node src/seed.js"
  },
  "dependencies": {
    "@prisma/client":      "^5.11.0",
    "bcryptjs":            "^2.4.3",
    "cors":                "^2.8.5",
    "dotenv":              "^16.4.5",
    "excel4node":          "^1.8.2",
    "express":             "^4.18.3",
    "express-async-errors":"^3.1.1",
    "jsonwebtoken":        "^9.0.2",
    "multer":              "^1.4.5-lts.1",
    "xlsx":                "^0.18.5"
  },
  "devDependencies": {
    "nodemon": "^3.1.0",
    "prisma":  "^5.11.0"
  }
}
